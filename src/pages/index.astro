---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Marc Krevitz — Furniture · Tech Projects · Chess · Work">
	<section class="hero">
		<span class="mono">Workshop · Board · Codebase</span>
		<h1>Marc Krevitz</h1>
		<p class="tagline">A tech specialist with too many hobbies.</p>
		<p class="bio">
			I've spent four years in the tech industry and most of my life falling down hobby rabbit
			holes. The current rotation: refurbishing vintage tech, restoring furniture, and DIY audio.
			I've also coached chess for five years. Everything here is something I make, fix, teach, or
			review.
		</p>
	</section>

	<section class="grid" aria-label="Site sections">
		<a class="card" href="/furniture">
			<h2>Furniture</h2>
			<p>Refurbishment projects and honest reviews.</p>
			<span class="go">View projects &amp; reviews →</span>
		</a>
		<a class="card" href="/tech-projects">
			<h2>Tech Projects</h2>
			<p>Tech refurbishment and other DIY projects.</p>
			<span class="go">View the Bench →</span>
		</a>
		<a class="card" href="/chess">
			<h2>Chess</h2>
			<p>Coaching and lessons for players of all skill levels.</p>
			<span class="go">Book a lesson →</span>
		</a>
		<a class="card" href="/work">
			<h2>Professional Work</h2>
			<p>Automation, software, and IT projects.</p>
			<span class="go">View work →</span>
		</a>
	</section>
</Layout>
