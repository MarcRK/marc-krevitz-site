---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Marc Krevitz - Furniture · Tech Projects · Chess · Work">
	<section class="hero">
		<span class="mono">Workshop · Workspace · Blog</span>
		<h1>Marc Krevitz</h1>
		<p class="tagline">A tech specialist with too many hobbies.</p>
		<p class="tagline-aside">(I promise I'm not as cold as my writing style suggests, just trying to keep things concise!)</p>
		<p class="bio">
			I've spent four years in the tech industry and most of my life falling down hobby rabbit
			holes. The current rotation: refurbishing vintage tech, restoring furniture, and DIY audio.
			I've also coached chess for five years. Everything here is something I make, fix, teach, or
			review.
		</p>
	</section>

	<section class="grid" aria-label="Site sections">
		<a class="card" href="/work">
			<h2>Professional Work</h2>
			<p>Automation, software, and IT projects.</p>
			<span class="go">View work →</span>
		</a>
		<a class="card" href="/furniture">
			<h2>Furniture</h2>
			<p>Refurbishment projects and honest reviews.</p>
			<span class="go">View projects &amp; reviews →</span>
		</a>
		<a class="card" href="/tech-projects">
			<h2>Tech Projects</h2>
			<p>Tech refurbishment and other DIY projects.</p>
			<span class="go">View the Bench →</span>
		</a>
		<a class="card" href="/chess">
			<h2>Chess</h2>
			<p>Coaching and lessons for players of all skill levels.</p>
			<span class="go">Book a lesson →</span>
		</a>
	</section>

	<section class="about-section" aria-label="About this site">
		<a class="about-strip" href="/about">
			<div class="about-strip-text">
				<span class="mono">About</span>
				<h2>About this site</h2>
				<p>How this site was built, and what it's built with.</p>
			</div>
			<span class="go">Read more →</span>
		</a>
	</section>
</Layout>

<style>
	.grid {
		padding-bottom: 16px;
	}

	.about-section {
		padding-bottom: 96px;
	}

	.about-strip {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 16px;
		padding: 24px;
		border: 1px solid var(--grey-3);
		border-radius: var(--radius);
		background: #FFFFFF;
		transition: border-color 0.15s, transform 0.15s;
	}

	.about-strip:hover {
		border-color: var(--accent);
		transform: translateY(-2px);
	}

	.about-strip-text h2 {
		font-size: 1.05rem;
		font-weight: 600;
		letter-spacing: -0.01em;
		margin: 4px 0 4px;
	}

	.about-strip-text p {
		font-size: 0.9rem;
		color: var(--grey-1);
	}

	.about-strip .go {
		font-size: 0.85rem;
		color: var(--grey-2);
		white-space: nowrap;
		transition: color 0.15s;
	}

	.about-strip:hover .go {
		color: var(--accent);
	}
</style>
