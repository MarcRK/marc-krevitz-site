---
import Layout from "../layouts/Layout.astro";
import TestimonialList from "../components/TestimonialList.astro";
import { chessTestimonials } from "../data/testimonials";

const LICHESS_URL = "https://lichess.org/@/MarcKrev";

// Decided: rates are on-request, not published publicly.
const RATES_ARE_PUBLIC = false;
---

<Layout
	title="Chess — Marc Krevitz"
	description="Chess coaching for players of all skill levels. Five years of coaching experience."
>
	<section class="page-header">
		<span class="mono">Chess</span>
		<h1>Chess coaching</h1>
		<p>Five years coaching players of all skill levels, from first-time players to tournament competitors.</p>
	</section>

	<section class="section" aria-label="How lessons work">
		<h2 class="section-heading">How lessons work</h2>
		<div class="post-list">
			<div class="info-card">
				<div class="post-body">
					<h3>1. Book a time</h3>
					<p>Reach out through the contact form with your availability and current level.</p>
				</div>
			</div>
			<div class="info-card">
				<div class="post-body">
					<h3>2. First session</h3>
					<p>We start with a quick assessment so lessons target what will actually improve your game.</p>
				</div>
			</div>
			<div class="info-card">
				<div class="post-body">
					<h3>3. Ongoing coaching</h3>
					<p>Recurring sessions covering openings, tactics, endgames, and reviewing your own games.</p>
				</div>
			</div>
		</div>
		<p style="margin-top: 24px;">
			<a class="btn btn-lg" href="/contact?intent=chess">Book a lesson</a>
		</p>
	</section>

	<section class="section" aria-label="Lichess profile">
		<h2 class="section-heading">Lichess</h2>
		<p>
			<a href={LICHESS_URL}>View my Lichess profile →</a>
		</p>
	</section>

	<section class="section" aria-label="Rates">
		<h2 class="section-heading">Rates</h2>
		{RATES_ARE_PUBLIC ? (
			<p>Rate details go here once published.</p>
		) : (
			<p>Rates are available on request — reach out via the contact form for current pricing.</p>
		)}
	</section>

	<section class="section" aria-label="Testimonials">
		<h2 class="section-heading">What students say</h2>
		<TestimonialList items={chessTestimonials} />
	</section>
</Layout>
