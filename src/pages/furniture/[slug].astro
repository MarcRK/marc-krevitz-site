---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
	const posts = await getCollection("furniture", ({ data }) => import.meta.env.DEV || !data.draft);
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}

const post = Astro.props;
const { Content } = await render(post);
const dateLabel = post.data.date.toLocaleDateString("en-US", {
	year: "numeric",
	month: "long",
	day: "numeric",
	timeZone: "UTC",
});
---

<Layout title={`${post.data.title} — Marc Krevitz`} description={post.data.summary}>
	<article class="article">
		<a class="back-link" href="/furniture">← Back to Furniture</a>
		<header>
			<span class="mono">{post.data.category}</span>
			<h1 class="article-title">{post.data.title}</h1>
			<p class="article-meta">{dateLabel}</p>
		</header>

		{post.data.images?.map((image) => <img src={image.src} alt={image.alt} />)}

		<div class="prose">
			<Content />
		</div>
	</article>
</Layout>
