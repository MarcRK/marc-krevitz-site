---
import Layout from "../../layouts/Layout.astro";
import PostCard from "../../components/PostCard.astro";
import TestimonialList from "../../components/TestimonialList.astro";
import { getCollection } from "astro:content";
import { furnitureTestimonials } from "../../data/testimonials";

const posts = (
	await getCollection("furniture", ({ data }) => import.meta.env.DEV || !data.draft)
).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const MARKETPLACE_URL = "https://www.facebook.com/marketplace/profile/100004986188540/";
---

<Layout title="Furniture — Marc Krevitz" description="Furniture refurbishment projects and honest reviews.">
	<section class="page-header">
		<span class="mono">Furniture</span>
		<h1>Refurbishment projects &amp; reviews</h1>
		<p>Before/after project logs, product reviews, reviews from clients, and any other thoughts.</p>
	</section>

	<section class="section" aria-label="Projects and reviews">
		<h2 class="section-heading">Projects &amp; Reviews</h2>
		<div class="post-list">
			{posts.map((post) => (
				<PostCard
					href={`/furniture/${post.id}/`}
					title={post.data.title}
					summary={post.data.summary}
					image={post.data.images?.[0]}
				/>
			))}
		</div>
	</section>

	<section class="section" aria-label="What clients say">
		<h2 class="section-heading">What clients say</h2>
		<TestimonialList items={furnitureTestimonials} />
		<p class="form-note">All reviews (Facebook Marketplace and chess coaching) have been anonymized.</p>
		<p class="form-note"><a href={MARKETPLACE_URL}>View my Facebook Marketplace listings →</a></p>
	</section>
</Layout>
